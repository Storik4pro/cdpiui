<?xml version="1.0" encoding="utf-8"?>
<template:TemplateWindow
    x:Name="MainWindow"
    x:Class="CDPI_UI.ModernMainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CDPI_UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:winex="using:WinUIEx"
    xmlns:l="using:WinUI3Localizer"
    xmlns:template="using:CDPI_UI.Default"
    xmlns:wc="using:CDPI_UI.Controls.WindowControls">

    <template:TemplateWindow.SystemBackdrop>
        <MicaBackdrop />
    </template:TemplateWindow.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <wc:TitleBarUserControl 
            x:Name="TitleBarUserControl"
            Height="43"/>
        <NavigationView x:Name="NavView"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        AlwaysShowHeader="True"
                        PaneDisplayMode="Top"
                        ExpandedModeThresholdWidth="500"
                        SelectionFollowsFocus="Disabled"
                        IsTabStop="False"
                        Grid.Row="1" 
                        Grid.ColumnSpan="2"
                        Loaded="NavView_Loaded"
                        ItemInvoked="NavView_ItemInvoked"
                        BackRequested="NavView_BackRequested">

            <NavigationView.MenuItems>
                <NavigationViewItem l:Uids.Uid="HomeButton" Tag="CDPI_UI.Views.ModernMainPage" Icon="Home"/>

                <NavigationViewItem l:Uids.Uid="UtilsButton" Tag="CDPI_UI.Views.UtilsPage" >
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7B8;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem l:Uids.Uid="SettingsButton" Tag="CDPI_UI.Views.SettingsPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" FontSize="16"  />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem l:Uids.Uid="AboutButton" Tag="CDPI_UI.Views.AboutPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" FontSize="16" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Margin="0,0,0,0"/>
        </NavigationView>
    </Grid>
</template:TemplateWindow>
