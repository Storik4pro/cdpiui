<?xml version="1.0" encoding="utf-8"?>
<template:TemplateWindow
    xmlns:ex="using:WinUIEx"
    x:Class="CDPI_UI.OfflineHelpWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CDPI_UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:animatedvisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    mc:Ignorable="d"
    xmlns:controls="using:CommunityToolkit.Labs.WinUI.MarkdownTextBlock"
    xmlns:l="using:WinUI3Localizer"
    xmlns:template="using:CDPI_UI.Default"
    xmlns:wc="using:CDPI_UI.Controls.WindowControls">

    <template:TemplateWindow.SystemBackdrop>
        <MicaBackdrop />
    </template:TemplateWindow.SystemBackdrop>

    <Grid x:Name="MainGrid">
        <Grid.Resources>
            <Thickness x:Key="NavigationViewContentMargin">0,43,0,0</Thickness>
            <Thickness x:Key="NavigationViewMinimalContentMargin">0,43,0,0</Thickness>
            <Thickness x:Key="NavigationViewHeaderMargin">0,0,0,0</Thickness>
        </Grid.Resources>
        <wc:TitleBarUserControl 
            x:Name="TitleBarUserControl"
            Height="48"
            ShowControlsContent="True"
            VerticalAlignment="Top"
            ControlsContentMinWidth="48"
            Canvas.ZIndex="1">
            <wc:TitleBarUserControl.ControlsContent>
                <Button x:Name="BackButton" 
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Width="30"
                        Height="30"
                        Padding="6"
                        PointerEntered="BackButton_PointerEntered" 
                        PointerExited="BackButton_PointerExited"
                        Click="BackButton_Click"
                        Visibility="Collapsed">
                    <AnimatedIcon x:Name="SearchAnimatedIcon">
                        <AnimatedIcon.Source>
                            <animatedvisuals:AnimatedBackVisualSource/>
                        </AnimatedIcon.Source>
                        <AnimatedIcon.FallbackIconSource>
                            <SymbolIconSource Symbol="Back"/>
                        </AnimatedIcon.FallbackIconSource>
                    </AnimatedIcon>
                </Button>
            </wc:TitleBarUserControl.ControlsContent>
        </wc:TitleBarUserControl>
        <Grid Margin="0,0,0,0" Padding="0">
            <NavigationView x:Name="HelpNavigationView" IsBackButtonVisible="Collapsed" IsSettingsVisible="False"
                            Canvas.ZIndex="0" SelectionChanged="HelpNavigationView_SelectionChanged"
                            IsTitleBarAutoPaddingEnabled="False"> 
                
                <NavigationView.FooterMenuItems>
                    <NavigationViewItem Content="About" Tag="AboutHelp">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE946;" />
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </NavigationView.FooterMenuItems>
                <ScrollViewer x:Name="ContentGrid" Grid.Column="1" Padding="20 0 20 0">
                    <controls:MarkdownTextBlock 
                        Margin="0 20" x:Name="MarkdownTextBlock" 
                        Config="{x:Bind MarkdownConfig, Mode=OneTime}"
                        UseAutoLinks="False"
                        UseEmphasisExtras="True"
                        UseListExtras="True"
                        UsePipeTables="True"
                        UseTaskLists="True"
                        DisableLinks="False"
                        OnLinkClicked="MarkdownTextBlock_OnLinkClicked"/>
                </ScrollViewer>
            </NavigationView>
             
            
        </Grid>
    </Grid>
</template:TemplateWindow>
