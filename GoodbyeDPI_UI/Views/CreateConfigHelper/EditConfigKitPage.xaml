<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="MainPage"
    x:Class="CDPI_UI.Views.CreateConfigHelper.EditConfigKitPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CDPI_UI.Views.CreateConfigHelper"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:l="using:WinUI3Localizer"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:lcontrols="using:CDPI_UI.Controls.CreateConfigHelper"
    xmlns:viewmodels="using:CDPI_UI.ViewModels">

    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="WideLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="{StaticResource Breakpoint640Plus}" />
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="NarrowLayout">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="CancelButton.MinWidth" Value="0" />
                        <Setter Target="CancelButton.Padding" Value="6" />
                        <Setter Target="CancelTextBlock.Visibility" Value="Collapsed" />
                        <Setter Target="SaveAsButton.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="SaveButton.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="RightControlColumn.Width" Value="*" />
                        <Setter Target="SeparatorControlItem.Width" Value="10" />
                        
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
            <VisualStateGroup x:Name="WindowStates">
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1382"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="CancelButton.HorizontalAlignment" Value="Center"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>

                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid x:Name="LoadingGrid" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <ProgressRing IsIndeterminate="True"/>
            <TextBlock l:Uids.Uid="WorkingOnItTextBlock" Grid.Row="1"/>
        </Grid>
        <ScrollView Padding="0 0 0 5"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Auto">
            <StackPanel Spacing="10" Margin="20 20 20 20">
                <TextBlock x:Name="PageTitleTextBlock" l:Uids.Uid="EditConfigKitMenuItem" FontWeight="Light" FontSize="28"/>
                <ListView x:Name="ConfigsListView" ItemContainerStyle="{StaticResource ListViewItemStretchStyle}" Visibility="Visible">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:ViewConfigInKitModel">
                            <lcontrols:ConfigUserControl
                                Guid="{x:Bind Guid, Mode=OneWay}"
                                TargetComponentId="{x:Bind TargetComponentId, Mode=OneWay}"
                                DisplayName="{x:Bind DisplayName, Mode=OneWay}"
                                UsedSiteLists="{x:Bind UsedSiteLists, Mode=OneWay}"
                                ExcludedSiteLists="{x:Bind ExcludedSiteLists, Mode=OneWay}"
                                LastEditTime="{x:Bind LastEditTime, Mode=OneWay}"
                                RemoveCommand="{Binding RemoveConfigCommand, ElementName=MainPage}"
                                RenameCommand="{Binding RenameConfigCommand, ElementName=MainPage}"
                                EditCommand="{Binding EditConfigCommand, ElementName=MainPage}"
                                OpenFileDirectoryCommand="{Binding OpenDirectoryCommand, ElementName=MainPage}"
                                />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="5"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>
                
            </StackPanel>
        </ScrollView>
        <Grid Grid.Row="1">
            <Rectangle Fill="{ThemeResource SolidBackgroundFillColorBaseBrush}"/>
            <Grid Padding="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition x:Name="SeparatorControlItem" Width="*"/>
                    <ColumnDefinition x:Name="RightControlColumn" Width="auto"/>
                </Grid.ColumnDefinitions>
                <Grid.ChildrenTransitions>
                    <ReorderThemeTransition/>
                </Grid.ChildrenTransitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <Button x:Name="CancelButton" MinWidth="150" Click="CancelButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon Glyph="&#xE711;" FontSize="16"/>
                            <TextBlock x:Name="CancelTextBlock" l:Uids.Uid="CancelTextBlock"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <Grid Grid.Column="2" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="SaveAsButton" MinWidth="150" Click="SaveAsButton_Click" Style="{ThemeResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon Glyph="&#xE792;" FontSize="16"/>
                            <TextBlock l:Uids.Uid="SaveMenuItem"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="SaveButton" MinWidth="150" Grid.Column="2">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                            <TextBlock l:Uids.Uid="SaveTextBlock"/>
                        </StackPanel>
                        <Button.Flyout>
                            <Flyout x:Name="SaveConfirmationFlyout" Opened="SaveConfirmationFlyout_Opened" Closed="SaveConfirmationFlyout_Closed" Placement="TopEdgeAlignedRight">
                                <Grid Width="350">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock l:Uids.Uid="AreYouSureTextBlock" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock l:Uids.Uid="SaveConfirmation" Grid.Row="2" TextWrapping="Wrap"/>
                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button l:Uids.Uid="YesButton" Click="SaveButton_Click" HorizontalAlignment="Stretch"/>
                                        <Button l:Uids.Uid="CancelButton" x:Name="CloseFlyoutButton" Grid.Column="2" Click="CloseFlyoutButton_Click"  HorizontalAlignment="Stretch" Style="{ThemeResource AccentButtonStyle}"/>
                                    </Grid>
                                </Grid>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
