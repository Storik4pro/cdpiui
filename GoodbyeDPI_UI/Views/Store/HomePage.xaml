<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="StoreHomePage"
    x:Class="CDPI_UI.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CDPI_UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:helper="using:CDPI_UI.Helper"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls" 
    xmlns:animation="using:System.Windows.Media.Animation"
    xmlns:labs="using:CommunityToolkit.Labs.WinUI"
    xmlns:l="using:WinUI3Localizer">

    <Page.Resources>
        <ItemsPanelTemplate x:Key="DefaultItemsPanel">
            <ItemsWrapGrid 
                Orientation="Vertical"
                ItemWidth="{Binding DataContext.LargeElementWidth, ElementName=StoreHomePage, Mode=OneWay}"/>
        </ItemsPanelTemplate>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid x:Name="LoadingGrid" HorizontalAlignment="Center" VerticalAlignment="Stretch" Canvas.ZIndex="10">
            <StackPanel VerticalAlignment="Center">
                <Image Source="/Assets/Icons/Store.png" Width="100" Margin="0, 0, 0, 20"/>
                <ProgressRing IsActive="True" Background="Transparent"/>
                
            </StackPanel>
            <TextBlock l:Uids.Uid="StoreUpdatingTextBlock"
                       MaxWidth="400" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                       VerticalAlignment="Bottom" Margin="0, 0, 0, 20"/>
        </Grid>
        <Grid 
            x:Name="ErrorScrollViewer"
            Padding="20 0 20 20"
            Margin="0"
            IsTabStop="False"
            UseSystemFocusVisuals="False"
            Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0, 0, 0, 10" Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid HorizontalAlignment="Center">
                    <BitmapIcon UriSource="ms-appx:///Assets/icons/store.png" ShowAsMonochrome="True" Width="100"/>
                    <FontIcon Glyph="&#xF736;" Foreground="{ThemeResource SystemFillColorCautionBackgroundBrush}" VerticalAlignment="Bottom" HorizontalAlignment="Left" FontSize="52" Margin="-10 0 0 0"/>
                    <FontIcon Glyph="&#xE7BA;" Foreground="{ThemeResource SystemFillColorCautionBrush}" VerticalAlignment="Bottom" HorizontalAlignment="Left"  FontSize="52" Margin="-10 0 0 0"/>
                </Grid>
                <TextBlock l:Uids.Uid="StoreDatabaseErrorTextBlock" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="20, 15, 0, 0"
                            TextWrapping="Wrap" MaxLines="10" Grid.Row="1" VerticalAlignment="Center"/>
            </Grid>
            <toolkit:WrapPanel Orientation="Horizontal" HorizontalSpacing="8" Grid.Row="1" HorizontalAlignment="Center">
                <HyperlinkButton l:Uids.Uid="/Flashlight/HowToFixThisProblem" x:Name="StoreLoadFixButton" Click="StoreLoadFixButton_Click" Padding="6 0"/>
                <Rectangle VerticalAlignment="Stretch" Fill="{ThemeResource TextFillColorPrimary}" Width="1" Margin="0 2"/>
                <HyperlinkButton l:Uids.Uid="/Flashlight/WhatIsStore" x:Name="WhatIsStoreButton" Click="WhatIsStoreButton_Click"  Padding="6 0"/>
                <Rectangle VerticalAlignment="Stretch" Fill="{ThemeResource TextFillColorPrimary}" Width="1" Margin="0 2"/>
                <HyperlinkButton l:Uids.Uid="/Flashlight/AskSupport" x:Name="AskSupportButton" Click="AskSupportButton_Click" Padding="6 0"/>
            </toolkit:WrapPanel>
            <Grid HorizontalAlignment="Center" Margin="0, 20, 0, 0" Grid.Row="2">
                <TextBlock x:Name="ErrorCodeText" Text="FLASHLIGHT_BUSY" IsTextSelectionEnabled="True"/>
            </Grid>
        </Grid>
        <ScrollViewer
            x:Name="StoreScrollViewer"
            Grid.Row="0"
            Padding="20,0,5,0"
            Margin="0, 20, 0, 0"
            IsTabStop="False"
            UseSystemFocusVisuals="False"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto"
            HorizontalScrollMode="Enabled"
            HorizontalScrollBarVisibility="Hidden"
            Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="StoreMainGridColumnDefinition" Width="*" MaxWidth="1860" MinWidth="1860"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="StoreStackPanel" Grid.Column="1">
                    
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
