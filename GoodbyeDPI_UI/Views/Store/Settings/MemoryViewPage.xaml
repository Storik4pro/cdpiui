<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CDPI_UI.Views.Store.Settings.MemoryViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CDPI_UI.Views.Store.Settings"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:l="using:WinUI3Localizer"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:memcontrols="using:CDPI_UI.Controls.Store.Settings"
    xmlns:viewmodels="using:CDPI_UI.ViewModels">

    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowStates">
                <VisualState x:Name="SmallState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainStackPanel.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="MainStackPanel.Width" Value="auto" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1975"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainStackPanel.HorizontalAlignment" Value="Center" />
                        <Setter Target="MainStackPanel.Width" Value="1860" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <ScrollViewer Padding="20">
            <StackPanel x:Name="MainStackPanel" Spacing="5">
                <Grid x:Name="NavGrid">
                    <Rectangle Fill="Transparent"/>
                    <BreadcrumbBar x:Name="BreadcrumbBar" ItemClicked="BreadcrumbBar_ItemClicked">
                        <BreadcrumbBar.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:BreadcrumbBarModel">
                                <BreadcrumbBarItem Content="{Binding}" AutomationProperties.Name="{Binding DisplayName}" Tag="{Binding Tag}">
                                    <BreadcrumbBarItem.ContentTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayName}" Style="{ThemeResource TitleTextBlockStyle}"/>
                                        </DataTemplate>
                                    </BreadcrumbBarItem.ContentTemplate>
                                </BreadcrumbBarItem>
                            </DataTemplate>
                        </BreadcrumbBar.ItemTemplate>
                    </BreadcrumbBar>
                </Grid>
                <ListView x:Name="DiskInfoListView" IsItemClickEnabled="False" ItemContainerStyle="{StaticResource ListViewItemStretchStyle}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:MemoryDiskViewModel">
                            <memcontrols:MemoryDiskUsageViewUserControl DiskLetter="{x:Bind DiskLetter, Mode=OneWay}"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="10"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
