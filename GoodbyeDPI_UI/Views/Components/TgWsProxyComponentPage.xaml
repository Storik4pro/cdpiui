<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Name="RootPage"
    x:Class="CDPI_UI.Views.Components.TgWsProxyComponentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CDPI_UI.Views.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:l="using:WinUI3Localizer"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls" 
    xmlns:lcontrol="using:CDPI_UI.Controls.ComponentSettings"
    xmlns:ucontrols="using:CDPI_UI.Controls.Universal"
    xmlns:models="using:CDPI_UI.ViewModels"
    xmlns:conv="using:CDPI_UI.Converters">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Storyboard x:Name="ShowInfoBarAnimation">
            <DoubleAnimation From="100" To="0" Duration="00:00:0.4" 
                             Storyboard.TargetName="InfoBarTranslateTransform" 
                             Storyboard.TargetProperty="X">
                <DoubleAnimation.EasingFunction>
                    <QuinticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Name="HideInfoBarAnimation">
            <DoubleAnimation From="0" To="1000" Duration="00:00:0.4" 
                             Storyboard.TargetName="InfoBarTranslateTransform" 
                             Storyboard.TargetProperty="X">
                <DoubleAnimation.EasingFunction>
                    <QuinticEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <ScrollView Padding="0 0">
            <StackPanel Spacing="20" Margin="20 0 20 20">
                <StackPanel x:Name="ContentStackPanel" Spacing="20" Visibility="Collapsed">
                    <controls:SettingsCard l:Uids.Uid="ConfigSettingsCard"
                                           CornerRadius="10"
                                           BorderBrush="{ThemeResource CardStrokeColorDefaultSolidBrush}">
                        <ComboBox x:Name="ConfigChooseCombobox" 
                                  MinWidth="400"
                                  SelectionChanged="ConfigChooseCombobox_SelectionChanged"
                                  Height="47">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="local:ComboboxItem">
                                    <StackPanel>
                                        <TextBlock Text="{Binding name}"/>
                                        <TextBlock Text="{Binding packName}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiary}"/>
                                    </StackPanel>
                                </DataTemplate>

                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </controls:SettingsCard>
                    <StackPanel x:Name="TilesStackPanel" Visibility="Collapsed" Spacing="20">
                        <StackPanel.ChildrenTransitions>
                            <RepositionThemeTransition />
                        </StackPanel.ChildrenTransitions>
                        <ListView x:Name="DataCentersListView"
                          ItemContainerStyle="{StaticResource ListViewItemStretchStyle}">
                            <ListView.Header>
                                <Grid Margin="0 0 0 5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock l:Uids.Uid="DataCentersTextBlock" Grid.Row="1" Grid.ColumnSpan="6" VerticalAlignment="Center" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="5">
                                        <Button x:Name="PasteFromBufferButton" Click="PasteFromBufferButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <FontIcon Glyph="&#xE77F;" FontSize="16" />
                                                <TextBlock l:Uids.Uid="PasteFromBufferTextBlock"/>
                                            </StackPanel>
                                            <Button.KeyboardAccelerators>
                                                <KeyboardAccelerator Modifiers="Control" Key="V"/>
                                            </Button.KeyboardAccelerators>
                                        </Button>
                                        <Button x:Name="AddButton" Click="AddButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <FontIcon Glyph="&#xE710;" FontSize="16" />
                                                <TextBlock l:Uids.Uid="AddTextBlock"/>
                                            </StackPanel>
                                            <Button.KeyboardAccelerators>
                                                <KeyboardAccelerator Modifiers="Control" Key="N"/>
                                            </Button.KeyboardAccelerators>
                                        </Button>
                                        <Button x:Name="ShareButton" Click="ShareButton_Click">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <FontIcon Glyph="&#xE72D;" FontSize="16" />
                                                <TextBlock l:Uids.Uid="ShareTextBlock"/>
                                            </StackPanel>
                                            <Button.KeyboardAccelerators>
                                                <KeyboardAccelerator Modifiers="Control" Key="C"/>
                                            </Button.KeyboardAccelerators>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ViewTelegramDataCenterModel">
                                    <lcontrol:TgWsDataCenterUserControl 
                                Guid="{x:Bind Guid, Mode=OneWay}" 
                                Number="{x:Bind Number, Mode=OneWay}" 
                                Ip="{x:Bind Ip, Mode=OneWay}"
                                EditCommand="{Binding DataContext.TgWsProxyEditCommand, ElementName=RootPage}"
                                RemoveCommand="{Binding DataContext.TgWsProxyRemoveCommand, ElementName=RootPage}"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="5"/>
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                        </ListView>
                        <StackPanel Spacing="5">
                            <controls:SettingsExpander l:Uids.Uid="LogsPerformanceSettingsExpander">
                                <controls:SettingsExpander.Items>
                                    <controls:SettingsCard l:Uids.Uid="BufferSettingsCard">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="BufferSizeTextBox"/>
                                            <Button x:Name="ResetBufferButton" 
                                            l:Uids.Uid="ResetByDefaultButton"
                                            Grid.Column="3" Padding="6" 
                                            VerticalAlignment="Bottom" Margin="10 0 0 0" 
                                            Height="32" Width="32"
                                            Click="ResetBufferButton_Click">
                                                <FontIcon Glyph="&#xE777;" FontSize="16"/>
                                            </Button>
                                        </StackPanel>
                                    </controls:SettingsCard>

                                    <controls:SettingsCard l:Uids.Uid="WebSocketSettingsCard">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="WebSocketSizeTextBox"/>
                                            <Button x:Name="ResetWebSocketSizeButton" 
                                            l:Uids.Uid="ResetByDefaultButton"
                                            Grid.Column="3" Padding="6" 
                                            VerticalAlignment="Bottom" Margin="10 0 0 0" 
                                            Height="32" Width="32"
                                            Click="ResetWebSocketSizeButton_Click">
                                                <FontIcon Glyph="&#xE777;" FontSize="16"/>
                                            </Button>
                                        </StackPanel>
                                    </controls:SettingsCard>

                                    <controls:SettingsCard l:Uids.Uid="AdvancedLoggingSettingsExpander">
                                        <ToggleSwitch x:Name="AdvancedLoggingToogleSwitch"/>
                                    </controls:SettingsCard>

                                    <controls:SettingsCard l:Uids.Uid="LogSizeSettingsCard">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="LogSizeTextBox"/>
                                            <Button x:Name="ResetLogSizeButton" 
                                            l:Uids.Uid="ResetByDefaultButton"
                                            Grid.Column="3" Padding="6" 
                                            VerticalAlignment="Bottom" Margin="10 0 0 0" 
                                            Height="32" Width="32"
                                            Click="ResetLogSizeButton_Click">
                                                <FontIcon Glyph="&#xE777;" FontSize="16"/>
                                            </Button>
                                        </StackPanel>
                                    </controls:SettingsCard>
                                </controls:SettingsExpander.Items>
                            </controls:SettingsExpander>
                        </StackPanel>
                        <ToggleButton x:Name="ProxySettingsVisibleToggleButton">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock l:Uids.Uid="ProxyAddrSettingsTextBlock"/>
                                <FontIcon Glyph="&#xE70D;" FontSize="16"/>
                            </StackPanel>
                        </ToggleButton>
                        <Grid Width="400" HorizontalAlignment="Left" Visibility="{Binding IsChecked, ElementName=ProxySettingsVisibleToggleButton, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock l:Uids.Uid="ProxyIpAddressTextBlock"/>
                                <TextBox x:Name="IPValue" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock l:Uids.Uid="PortTextBlock"/>
                                <TextBox x:Name="PortValue" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <Button x:Name="ResetButton" l:Uids.Uid="ResetByDefaultButton"
                                    Grid.Column="3" Padding="6" 
                                    VerticalAlignment="Bottom" Margin="10 0 0 0" 
                                    Height="32" Width="32"
                                    Click="ResetButton_Click">
                                <FontIcon Glyph="&#xE777;" FontSize="16"/>
                            </Button>
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="3" >
                                <TextBlock l:Uids.Uid="KeyTextBlock"/>
                                <TextBox x:Name="KeyValue" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                            <Button x:Name="ResetKeyButton" l:Uids.Uid="ResetByDefaultButton"
                                    Grid.Row="1" Grid.Column="3" Padding="6" 
                                    VerticalAlignment="Bottom" Margin="10 0 0 0" 
                                    Height="32" Width="32"
                                    Click="ResetKeyButton_Click">
                                <FontIcon Glyph="&#xE777;" FontSize="16"/>
                            </Button>
                        </Grid>
                        <ucontrols:LinkedSettingsUserControl x:Name="LinkedSettingsUserControl" ClickCommand="{Binding DataContext.LinkedSettingClickCommand, ElementName=RootPage}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel x:Name="EmptyStackPanel" Spacing="30" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="(◡︵◡)" Style="{ThemeResource SubheaderTextBlockStyle}"/>
                        <TextBlock l:Uids.Uid="EmptyPageTitle" Style="{ThemeResource SubheaderTextBlockStyle}" TextWrapping="NoWrap"/>
                        <TextBlock l:Uids.Uid="EmptyPageDescription" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button x:Name="CreateConfigButton" Grid.Column="1" Padding="6" Margin="0 0 10 0" Height="40" Click="CreateConfigButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <BitmapIcon UriSource="ms-appx:///Assets/Icons/Edit.png"  ShowAsMonochrome="False" Width="23" Height="23"/>
                            <TextBlock l:Uids.Uid="CreateConfigTextBlock" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
            </StackPanel>
        </ScrollView>
        
        <InfoBar
            x:Name="ActionInfoBar"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0 0 20 20"
            IsOpen="False"
            IsIconVisible="True"
            IsClosable="True"
            Closing="ActionInfoBar_Closing">
            <InfoBar.RenderTransform>
                <TranslateTransform x:Name="InfoBarTranslateTransform"/>
            </InfoBar.RenderTransform>
        </InfoBar>

        <Grid Grid.Row="1">
            <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"/>
            <Rectangle Fill="{ThemeResource SolidBackgroundFillColorSecondaryBrush}" Height="1" VerticalAlignment="Top"/>
            <Grid Padding="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE754;" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock l:Uids.Uid="/Flashlight/SaveBeforeQuitTip" Grid.Column="2" VerticalAlignment="Center"/>
                </Grid>
                <Button x:Name="CancelButton" l:Uids.Uid="CancelButton" Grid.Column="1" HorizontalAlignment="Stretch" Click="CancelButton_Click"/>
                <Button x:Name="SaveButton" Grid.Column="3" Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch" Click="SaveButton_Click">
                    <TextBlock l:Uids.Uid="SaveTextBlock"/>
                </Button>
                
            </Grid>
        </Grid>
        
    </Grid>
</Page>
