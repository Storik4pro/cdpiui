<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    l:Uids.Uid="TgWsDataCenterEditContentDialog"
    x:Class="CDPI_UI.Controls.Dialogs.ComponentSettings.TgWsDataCenterEditContentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CDPI_UI.Controls.Dialogs.ComponentSettings"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:l="using:WinUI3Localizer"
    DefaultButton="Primary"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    SecondaryButtonClick="ContentDialog_SecondaryButtonClick"
    Style="{ThemeResource DefaultContentDialogStyle}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <TextBlock l:Uids.Uid="NumberTextBlock" Grid.Row="0" Grid.Column="0"/>
        <TextBox x:Name="NumberTextBox" Grid.Row="1" Grid.Column="0"/>
        <TextBlock l:Uids.Uid="IpTextBlock" Grid.Row="0" Grid.Column="2"/>
        <TextBox x:Name="IpTextBox" Width="300" Grid.Row="1" Grid.Column="2"/>
    </Grid>
</ContentDialog>
