<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    l:Uids.Uid="XChangeListContentDialog"
    x:Class="CDPI_UI.Controls.Dialogs.ComponentSettings.ChangeSiteListContentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CDPI_UI.Controls.Dialogs.ComponentSettings"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:l="using:WinUI3Localizer"
    xmlns:viewmodels="using:CDPI_UI.ViewModels"
    xmlns:ucontrols="using:CDPI_UI.Controls.Universal"
    Style="{ThemeResource DefaultContentDialogStyle}"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    SecondaryButtonClick="ContentDialog_SecondaryButtonClick">

    <Grid>
        <StackPanel>
            <TextBlock l:Uids.Uid="ChangeListTipTextBlock" TextWrapping="Wrap"/>
            <SelectorBar x:Name="MainSelectorBar" SelectionChanged="MainSelectorBar_SelectionChanged">
                <SelectorBarItem l:Uids.Uid="FromTheStoreTextBlock" x:Name="FromTheStoreSelectorBarItem">
                    <SelectorBarItem.Icon>
                        <BitmapIcon UriSource="ms-appx:///Assets/Icons/Store.png" ShowAsMonochrome="True" Height="20"/>
                    </SelectorBarItem.Icon>
                </SelectorBarItem>
                <SelectorBarItem l:Uids.Uid="ManuallyTextBlock">
                    <SelectorBarItem.Icon>
                            <FontIcon Glyph="&#xE977;"/>
                    </SelectorBarItem.Icon>
                </SelectorBarItem>
            </SelectorBar>

            <Grid x:Name="StoreGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" MaxHeight="250"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <ucontrols:NoContentToDisplayUserControl l:Uids.Uid="NoSuitableStoreItemsFound" x:Name="StoreNoItemsPlaceholder"/>

                <ListView x:Name="StoreListView" SelectionChanged="StoreListView_SelectionChanged"  MaxHeight="180" Margin="0 0 -10 0">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:ViewSiteListModel">
                            <Grid Padding="0 10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE7C3;"/>
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{x:Bind Title}" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock Text="{x:Bind Developer}" Foreground="{ThemeResource TextFillColorTertiary}" Grid.Row="1" Margin="0 0 50 0" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind Size}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiary}" 
                                               Grid.Row="1" HorizontalAlignment="Right" TextAlignment="Right"/>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="0" Margin="0 0 10 0"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>
                <HyperlinkButton x:Name="ViewInStoreButton" Click="ViewInStoreButton_Click" Grid.Row="2">
                    <TextBlock l:Uids.Uid="FindNewItemsInStoreTextBlock"/>
                </HyperlinkButton>
            </Grid>

            <Grid x:Name="LocalGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" MaxHeight="250"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <ucontrols:NoContentToDisplayUserControl l:Uids.Uid="YouDontAddAnyFilesYet" x:Name="RecentFilesNotFoundPlaceholder"/>
                
                <ListView x:Name="ManualListView" SelectionChanged="ManualListView_SelectionChanged" MaxHeight="180" Margin="0 0 -10 0">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:ViewSiteListModel">
                            <Grid Padding="0 10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE7C3;"/>
                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{x:Bind Title}" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock Text="{x:Bind Developer}" Foreground="{ThemeResource TextFillColorTertiary}" Grid.Row="1" Margin="0 0 50 0" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind Size}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiary}" 
                               Grid.Row="1" HorizontalAlignment="Right" TextAlignment="Right"/>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="0" Margin="0 0 10 0"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                </ListView>
                
                <Button x:Name="SelectFileManuallyButton" Click="SelectFileManuallyButton_Click" Grid.Row="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE8E5;" />
                        <StackPanel Grid.Column="2">
                            <TextBlock l:Uids.Uid="SelectFileText" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                            <TextBlock l:Uids.Uid="SelectFileTipTextBlock"/>
                        </StackPanel>
                    </Grid>
                </Button>
            </Grid>

        </StackPanel>
    </Grid>
</ContentDialog>
